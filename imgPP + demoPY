uploaded1 = files.upload()
name1 = list(uploaded1.keys())[0]
img1_bgr = cv2.imdecode(np.frombuffer(uploaded1[name1], np.uint8), cv2.IMREAD_COLOR)

uploaded2 = files.upload()
name2 = list(uploaded2.keys())[0]
img2_bgr = cv2.imdecode(np.frombuffer(uploaded2[name2], np.uint8), cv2.IMREAD_COLOR)

print('=' * 52)
print('  COMBO 1 - CLAHE + BILATERAL FILTER')
print('  CLAHE boosts contrast -> Bilateral denoises')
print('  while preserving edges for keypoint detection.')
print('=' * 52)

def apply_clahe_bilateral(img, lbl):
    pbar(f'{lbl}: bgr -> lab', 1, 8)
    lab = cv2.cvtColor(img, cv2.COLOR_BGR2LAB)
    pbar(f'{lbl}: split l,a,b channels', 2, 8)
    l, a, b = cv2.split(lab)
    pbar(f'{lbl}: clahe object', 3, 8)
    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8, 8))
    pbar(f'{lbl}: apply clahe', 4, 8)
    l_eq = clahe.apply(l)
    pbar(f'{lbl}: merge', 5, 8)
    clahe_out = cv2.cvtColor(cv2.merge([l_eq, a, b]), cv2.COLOR_LAB2BGR)
    pbar(f'{lbl}: bilateral filter', 6, 8)
    result = cv2.bilateralFilter(clahe_out, d=9, sigmaColor=75, sigmaSpace=75)
    pbar(f'{lbl}: packing result', 7, 8)
    pbar(f'{lbl}: done', 8, 8)
    return result

cb1 = apply_clahe_bilateral(img1_bgr, 'img1')
cb2 = apply_clahe_bilateral(img2_bgr, 'img2')

print('  CLAHE + Bilateral done - showing results')
show_pair('Combo #1: CLAHE + Bilateral Filter',
          cv2.cvtColor(cb1, cv2.COLOR_BGR2RGB),
          cv2.cvtColor(cb2, cv2.COLOR_BGR2RGB))

